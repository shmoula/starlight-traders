{
  "meta": {
    "name": "Starlight Traders — Astro-Neon",
    "version": "1.0.0",
    "sourceOfTruth": "src/ui/tokens.css",
    "note": "Mirror of the CSS custom properties for design tooling. Keep in sync with tokens.css; the CSS file wins on conflict."
  },
  "color": {
    "background": {
      "space": "#060a0f",
      "nebula": "#0b1520",
      "panel": "rgba(13, 27, 42, 0.82)",
      "panelSolid": "#0d1b2a",
      "headerHi": "#1b3144",
      "headerLo": "#112233",
      "inset": "#081119",
      "rowAlt": "rgba(126, 190, 228, 0.04)"
    },
    "accent": {
      "cyan": {
        "core": "#00d9ff",
        "bright": "#8ceeff",
        "dim": "rgba(0, 217, 255, 0.4)",
        "tint": "rgba(0, 217, 255, 0.1)"
      },
      "gold": {
        "core": "#ffb84d",
        "bright": "#ffd89a",
        "dim": "rgba(255, 184, 77, 0.4)",
        "tint": "rgba(255, 184, 77, 0.1)"
      },
      "magenta": {
        "core": "#ff4d97",
        "bright": "#ff9ac4",
        "dim": "rgba(255, 77, 151, 0.45)",
        "tint": "rgba(255, 77, 151, 0.12)"
      },
      "orange": {
        "core": "#ff9838",
        "bright": "#ffcf96",
        "dim": "rgba(255, 152, 56, 0.5)",
        "tint": "rgba(255, 152, 56, 0.14)"
      }
    },
    "support": {
      "positive": "#57e6a8",
      "negative": "#ff6a55"
    },
    "text": {
      "hi": "#eaf6fb",
      "base": "#c2d6e2",
      "dim": "#8ba5b7",
      "faint": "#5d7789",
      "title": "#cfe9f4"
    },
    "border": {
      "neutral": "rgba(120, 170, 196, 0.24)",
      "panel": "rgba(86, 164, 196, 0.32)",
      "strong": "rgba(0, 217, 255, 0.55)"
    },
    "semantic": {
      "interactive": "{color.accent.cyan.core}",
      "currency": "{color.accent.gold.core}",
      "consumable": "{color.accent.magenta.core}",
      "alert": "{color.accent.orange.core}",
      "focusRing": "{color.accent.cyan.core}"
    }
  },
  "glow": {
    "cyan": "0 0 2px rgba(0, 217, 255, 0.55), 0 0 10px rgba(0, 217, 255, 0.35), 0 0 22px rgba(0, 217, 255, 0.15)",
    "gold": "0 0 2px rgba(255, 184, 77, 0.55), 0 0 10px rgba(255, 184, 77, 0.35), 0 0 22px rgba(255, 184, 77, 0.15)",
    "magenta": "0 0 2px rgba(255, 77, 151, 0.55), 0 0 10px rgba(255, 77, 151, 0.35), 0 0 22px rgba(255, 77, 151, 0.15)",
    "orange": "0 0 2px rgba(255, 152, 56, 0.55), 0 0 10px rgba(255, 152, 56, 0.35), 0 0 22px rgba(255, 152, 56, 0.15)",
    "panel": "0 0 0 1px rgba(0, 217, 255, 0.05), 0 0 18px rgba(0, 217, 255, 0.07), 0 10px 30px rgba(0, 0, 0, 0.45)",
    "textCyan": "0 0 8px rgba(0, 217, 255, 0.5)",
    "textGold": "0 0 8px rgba(255, 184, 77, 0.5)"
  },
  "typography": {
    "family": {
      "display": "\"Orbitron\", \"Exo 2\", ui-sans-serif, system-ui, sans-serif",
      "body": "\"Exo 2\", ui-sans-serif, system-ui, \"Segoe UI\", sans-serif",
      "mono": "ui-monospace, \"SF Mono\", Menlo, Consolas, monospace"
    },
    "size": {
      "2xs": "10px",
      "xs": "11px",
      "sm": "13px",
      "md": "14px",
      "lg": "16px",
      "xl": "20px",
      "2xl": "28px"
    },
    "tracking": {
      "tight": "0.04em",
      "label": "0.08em",
      "wide": "0.14em"
    },
    "leading": {
      "tight": 1.2,
      "body": 1.45
    }
  },
  "space": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "32px",
    "8": "48px",
    "padPanel": "{space.3}",
    "rowHeight": "40px",
    "controlHeight": "26px"
  },
  "radius": {
    "xs": "3px",
    "sm": "5px",
    "md": "8px",
    "lg": "12px",
    "chamfer": "14px"
  },
  "motion": {
    "durationFast": "120ms",
    "duration": "200ms",
    "durationSlow": "350ms",
    "ease": "cubic-bezier(0.2, 0.7, 0.3, 1)"
  },
  "z": {
    "bg": 0,
    "hud": 10,
    "overlay": 50,
    "toast": 90
  }
}
